(defn bytes->str [x]
  (if (bytes? x) (String. (bytes x))
      (str x)))

(defn read-msg [msg]
  (let [res (zipmap (map keyword (keys msg))
                    (map #(if (bytes? %)
                            (String. (bytes %))
                            %)
                         (vals msg)))
        _ (println :res res)
        res (if-let [status (:status res)]
              (assoc res :status (mapv bytes->str status))
              res)
        _ (println :res1 res)
        res (if-let [status (:sessions res)]
              (assoc res :sessions (mapv bytes->str status))
              res)]
        _ (println :res2 res)
    res))

(defn read-reply [in session id]
  (loop []
    (let [msg (read-msg (b/read-bencode in))]
      (if (and (= (:session msg) session)
               (= (:id msg) id))
        msg
        (recur)))))
(def current-id (atom 0))
(defn next-id []
  (str (swap! current-id inc)))
(defn read-port-from-process
  [reader timeout-ms]
  (let [sb (StringBuilder.)
        end (+ (System/currentTimeMillis) timeout-ms)]
    (loop []
      (while (.ready reader)
        (let [c (char (.read reader))]
          (.append sb c)))

      (let [s (str sb)]
        (println :XXXX s)
        (if-let [[_ port] (re-find #"nrepl://127\.0\.0\.1:(\d+)" s)]
          (Long/parseLong port)
          (if (< (System/currentTimeMillis) end)
            (do
              (Thread/sleep 500)
              (recur))
            (throw (ex-info "Timeout waiting for nREPL port"
                            {:output s}))))))))


(defn read-x
  [reader timeout-ms]
  (let [sb (StringBuilder.)
        end (+ (System/currentTimeMillis) timeout-ms)]
    (loop []
      (while (.ready reader)
        (let [c (char (.read reader))]
          (.append sb c)))

      (let [s (str sb)]
        (println :XXXX s)
        (if (< (System/currentTimeMillis) end)
          (do
            (Thread/sleep 500)
            (recur))
          (throw (ex-info "Timeout waiting for nREPL port"
                          {:output s})))))))

(defmacro with-server
  [& body]
  `(fs/with-temp-dir [tmp#]
     (let [timeout-ms# 2000
           proc# (ps/process ["jank" "repl"]
                             {:out :pipe
                              :dir tmp#})]
       (with-open [reader# (io/reader (:out proc#))]
         (try
           (let [port# (read-port-from-process reader# timeout-ms#)]
             (binding [*nrepl-port* port#]
               ~@body))
                      
           (finally
             (read-x reader# 2000)

             (ps/destroy proc#)))))))

(defn coerce-long [x]
  (if (string? x) (Long/parseLong x) x))

(defn encode-bytes [m]
  (let [out (java.io.ByteArrayOutputStream.)]
    (b/write-bencode out m)
    (.toByteArray out)))

