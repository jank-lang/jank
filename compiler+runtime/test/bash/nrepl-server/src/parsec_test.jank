(ns parsec-test
  (:require [clojure.test :refer [deftest is run-tests successful? testing]]
            [jank.nrepl.server.parsec :as p]))

(deftest digit-test
  (testing "single digit parser"
    (is (= [5 nil] (p/parse (p/digit) "5")))
    (is (= [5 "abc"] (p/parse (p/digit) "5abc")))
    (is (nil? (p/parse (p/digit) "abc")))
    (is (nil? (p/parse (p/digit) "a5bc")))
    (is (nil? (p/parse (p/digit) "")))))

(deftest one-char-test
  (testing "one-char parser"
    (is (= [\x nil] (p/parse (p/one-char \x) "x")))
    (is (= [\x "yz"] (p/parse (p/one-char \x) "xyz")))
    (is (nil? (p/parse (p/one-char \a) "xyz")))
    (is (nil? (p/parse (p/one-char \x) "yxz")))
    (is (nil? (p/parse (p/one-char \x) "")))))

(deftest any-char-test
  (testing "any-char parser"
    (is (= [\h "ello"] (p/parse (p/any-char) "hello")))
    (is (nil? (p/parse (p/any-char) "")))))

(deftest many-test
  (testing "many parser"
    (let [parser (p/many (p/one-char \a))]
      (is (= [[\a] "bcd"] (p/parse parser "abcd")))
      (is (= [[\a \a] "bcd"] (p/parse parser "aabcd")))
      (is (nil? (p/parse parser "xyz")))
      (is (nil? (p/parse parser ""))))))

(deftest many1-test
  (testing "many1 parser"
    (let [parser (p/many1 (p/one-char \a))]
      (is (= [[\a] "bcd"] (p/parse parser "abcd")))
      (is (= [[\a \a] "bcd"] (p/parse parser "aabcd")))
      (is (nil? (p/parse parser "xyaz")))
      (is (nil? (p/parse parser ""))))))

(deftest choice-test
  (testing "choice parser"
    (let [parser (p/choice (p/one-char \x) (p/one-char \y))]
      (is (= [\x "yz"] (p/parse parser "xyz")))
      (is (= [\y "xz"] (p/parse parser "yxz")))
      (is (= [\y "z"] (p/parse parser "yz")))
      (is (nil? (p/parse parser "abc")))
      (is (nil? (p/parse parser "abxc")))
      (is (nil? (p/parse parser ""))))))

(deftest number-test
  (testing "number parser"
    (is (= [42 "abc"] (p/parse (p/number) "42abc")))
    (is (= [-42 "abc"] (p/parse (p/number) "-42abc")))
    (is (nil? (p/parse (p/number) "abc")))
    (is (nil? (p/parse (p/number) "a42bc")))
    (is (nil? (p/parse (p/number) "")))))

(deftest sequencep-test
  (testing "sequence parser"
    (let [parser (p/sequencep (p/one-char \a) (p/one-char \b) (p/one-char \c))]
      (is (= [[\a \b \c] "def"] (p/parse parser "abcdef")))
      (is (nil? (p/parse parser "abxef")))
      (is (nil? (p/parse parser "xefabc")))
      (is (nil? (p/parse parser ""))))))

(deftest n-times-test
  (testing "n-times parser"
    (let [parser (p/n-times 3 (p/one-char \x))]
      (is (= [[\x \x \x] "yz"] (p/parse parser "xxxyz")))
      (is (= [[\x \x \x] "xyz"] (p/parse parser "xxxxyz")))
      (is (nil? (p/parse parser "xxz")))
      (is (nil? (p/parse parser "zxxx")))
      (is (nil? (p/parse parser ""))))))

(deftest mapp-test
  (testing "mapp parser"
    (let [parser (p/mapp inc (p/digit))]
      (is (= [6 "abc"] (p/parse parser "5abc")))
      (is (nil? (p/parse parser "abc")))
      (is (nil? (p/parse parser ""))))))

(deftest parse-basic
  (let [[result remaining] (p/parse (p/digit) "7xyz")]
    (is (= result 7))
    (is (= remaining "xyz")))

  (is (nil? (p/parse (p/digit) "abc"))))

(def this-nsym (ns-name *ns*))

(defn -main []
  (cpp/exit
    (if (successful? (run-tests this-nsym))
      0
      1)))

