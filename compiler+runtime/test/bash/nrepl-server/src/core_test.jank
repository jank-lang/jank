(ns core-test
  (:require [clojure.test :refer [deftest is run-tests successful? testing]]
            [jank.nrepl.server.bencode :as bencode]
            [jank.nrepl.server.core :as core]
            [connection-harness :as sf :refer [with-harness *driver* *sut** read-some! write-some!]]))

(deftest connected?-test
  (with-harness
    (is (core/connected? *driver*))
    (.close (cpp/* (cpp/unbox (:* jank.nrepl.server.native_client) *driver*)))
    (is (not (core/connected? *driver*)))))

(deftest read-message-test
  (with-harness
    (testing "parses single message"
      (let [msg (bencode/write {"op" "clone"})]
        (write-some! *driver*  msg)
        (let [[msg remainder] (core/read-message *sut** nil)]
          (is (= {"op" "clone"} msg))
          (is (nil? remainder)))))

    (testing "read message with remainder"
      (let [clone (str (bencode/write {"op" "clone"}))
            b (subs clone 0 5)
            e (subs clone 5)]
        (write-some! *driver* b)

        (let [[msg remainder] (core/read-message *sut** nil)]
          (is (some? remainder))
          (write-some! *driver* e)
          (let [[msg remainder] (core/read-message *sut** remainder)]
            (is (= {"op" "clone"} msg))))))))

(defn wait-until
  "Waits until PRED is true or TIMEOUT-MS expires, returning true if
  successful, otherwise false; may perform up to ceil(TIMEOUT-MS /
  INTERVAL-MS) checks, sleeping INTERVAL-MS between evaluations."
  [pred timeout-ms interval-ms]
  (let [steps (quot timeout-ms interval-ms)]
    (loop [i 0]
      (cond
        (pred) true
        (>= i steps) false
        :else
        (do
          (sleep interval-ms)
          (recur (inc i)))))))

(deftest wait-until-test
  (testing "predicate already true"
    (is (wait-until (fn [] true) 1000 100)))

  (testing "predicate becomes true before timeout"
    (let [state (atom false)]
      (future
        (sleep 200)
        (swap! state (constantly true)))
      (is (wait-until (fn [] @state) 1000 50))))

  (testing "predicate never becomes true (timeout)"
    (is (false? (wait-until (fn [] false) 300 50)))))

