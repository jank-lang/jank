(deftest handle-client-test
  (with-harness
    (let [server (future (core/handle-client *sut**))]
      (try
        (testing "op: clone"
          (let [msg (bencode/write {"op" "clone"})]
            (write-some! *driver* msg)
            (let [res (read-some! *driver*)
                  [dec rem] (bencode/parse res)]
              (is (nil? rem))
              (is (= {"new-session" :ignore, "status" ["done"]}
                     (assoc dec "new-session" :ignore))))
            ))

        (testing "op: simple eval"
          (let [msg (bencode/write {"op" "eval" "code" "5"})]
            (write-some! *driver* msg)
            (let [res1 (read-some! *driver*)
                  [dec1 rem1] (bencode/parse res1)]
              (is (= {"out" ""}
                     dec1))
              (let [res2 (read-some! *driver*)
                    [dec2 rem2] (bencode/parse (str rem1 res2))]
                (is (= {"err" ""}
                       dec2))
                (let [[dec3 rem3] (bencode/parse rem2)]
                  (is (= {"value" "5", "ns" "user", "status" ["done"]}
                         dec3)))))))

        (finally
          (when (core/connected? *sut**)
            (.close (cpp/* (cpp/unbox (:* jank.nrepl.server.native_client) *driver*)))
            (let [timeout-ms 1000
                  disconnected? (wait-until #(not (core/connected? *sut**)) timeout-ms 100)]
              (if disconnected?
                @server
                (is disconnected? (str "Failed to disconnected after " timeout-ms " ms"))))))))))

(def this-nsym (ns-name *ns*))

(defn -main []
  (cpp/exit
   (if (successful? (run-tests this-nsym))
     0
     1)))
