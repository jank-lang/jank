(let* [complement (fn* [f]
                    (fn*
                      ([] (not (f)))
                      ([x] (not (f x)))
                      ([x y] (not (f x y)))
                      ([x y & zs] (not (apply f x y zs)))))]
  (if (and (= true ((complement even?) 3))
           (= false ((complement even?) 4)))
    :success))
