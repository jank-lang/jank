(case 1 1   :one
  2         :two
  "3"       :three
  :default)

(case "3" 1   :one
  2           :two
  "3"         :three
  :default)

(case true true  :yes
  false          :no
  :default)

(case nil
  nil   :empty
  false :false-value
  :default)

(case 0
  0 :zero
  1 :one
  2 :two
  :default)

(case "hello" "world"   :world
  "hello"               :greeting
  "Clojure"             :language
  :default)

