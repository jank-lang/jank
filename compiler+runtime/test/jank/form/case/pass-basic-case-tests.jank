(case 3.14
  3.14 :pi
  2.71 :e
  1.61 :phi
  :default)

(assert
 (=
  (case 1
    1   :one
    2   :two
    "3" :three
    :default)
  :one))

(assert
 (=
  (case "3"
    1   :one
    2   :two
    "3" :three
    :default)
  :three))

(assert
 (=
  (case true
    true  :yes
    false :no
    :default)
  :yes))

(assert
 (=
  (case nil
    nil   :empty
    false :false-value
    :default)
  :empty))

(assert
 (=
  (case 0
    0 :zero
    1 :one
    2 :two
    :default)
  :zero))

(assert
 (=
  (case "hello"
    "world"   :world
    "hello"   :greeting
    "Clojure" :language
    :default)
  :greeting))

(assert
 (=
  (case 3.14
    3.14 :pi
    2.71 :e
    1.61 :phi
    :default)
  :pi))

(assert
 (=
  (case 'symbol symbol  :symbol-match
    other               :symbol-no-match
    :symbol-fallback)
  :symbol-match))

