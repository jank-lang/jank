; rand(10) is most likely not 1 or 2, so we expect :default
; test case in value position
(let [xfn
      (case (rand 10)
        1 :one
        2 :two
        :default)]
  (assert (= xfn :default)))

; rand(10) is most likely not 1 or 2, so we expect :default

; test case in statement position
(let [xfn (fn []
            (case (rand 10)
              1 :one
              2 :two
              :default)
            :arbitrary-value)]
  (assert (= (xfn) :arbitrary-value)))

; test case in return position
(assert
 (=
  (case (rand 10)
    1 :one
    2 :two
    :default)
  :default))

:success