;; case-ratio-test.clj

;; ==================================================
;; Test: (case 3/4 4/3 :four-thirds 3/4 :three-fourths :default)
;; ==================================================

;; Value position
(let [xfn (let* [test-val 3/4]
            (case* test-val
              0 ; shift
              0 ; mask
              :default
                       {2654435966 (clojure.core/condp clojure.core/= test-val 3/4 :three-fourths
                                     :default)
                        2654436025 (clojure.core/condp clojure.core/= test-val 4/3 :four-thirds
                                     :default)}
              :compact :hash-equiv nil))]
  (assert (= xfn :three-fourths) "Ratio value position test"))

;; Statement position
(let [xfn (fn []
            (let* [test-val 3/4]
              (case* test-val
                0 0 :default
                         {2654435966 (clojure.core/condp clojure.core/= test-val 3/4 :three-fourths
                                       :default)
                          2654436025 (clojure.core/condp clojure.core/= test-val 4/3 :four-thirds
                                       :default)}
                :compact :hash-equiv nil))
            :arbitrary-value)]
  (assert (= (xfn) :arbitrary-value) "Ratio statement position test"))

;; Return position (direct assertion)
(assert
 (=
   (let* [test-val 3/4]
     (case* test-val
       0 0 :default
                {2654435966 (clojure.core/condp clojure.core/= test-val 3/4 :three-fourths
                              :default)
                 2654436025 (clojure.core/condp clojure.core/= test-val 4/3 :four-thirds
                              :default)}
       :compact :hash-equiv nil))
   :three-fourths)
 "Ratio return position test")

:success