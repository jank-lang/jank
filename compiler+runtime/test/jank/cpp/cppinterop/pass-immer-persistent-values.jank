       _ (cpp/jank.cpp.cppinterop.pass_immer_persistent_values.atom_conj atom-holder 32)
       _ (assert (= [10 32] (cpp/jank.cpp.cppinterop.pass_immer_persistent_values.atom_snapshot atom-holder)))
       _ (assert (= 42 (cpp/jank.cpp.cppinterop.pass_immer_persistent_values.atom_exchange_sum atom-holder [7 8])))
       _ (assert (= [7 8] (cpp/jank.cpp.cppinterop.pass_immer_persistent_values.atom_snapshot atom-holder)))
