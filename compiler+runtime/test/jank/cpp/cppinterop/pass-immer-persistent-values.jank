       _ (assert (= 6 (cpp/jank.cpp.cppinterop.pass_immer_persistent_values.sum '(1 2 3))))
       _ (assert (= 0 (cpp/jank.cpp.cppinterop.pass_immer_persistent_values.sum nil)))
       _ (assert (= 0 (cpp/jank.cpp.cppinterop.pass_immer_persistent_values.vector_size nil)))
       nested-vector (cpp/jank.cpp.cppinterop.pass_immer_persistent_values.make_nested_vector)
       _ (assert (= [[1 2] [3 4]] nested-vector))
       _ (assert (= 15 (cpp/jank.cpp.cppinterop.pass_immer_persistent_values.sum_nested_vector [[2 3] [4 6]])))
       _ (assert (= 10 (cpp/jank.cpp.cppinterop.pass_immer_persistent_values.sum_with_immer_accumulate [1 2 3 4])))
