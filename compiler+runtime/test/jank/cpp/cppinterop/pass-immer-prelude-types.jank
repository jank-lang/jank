(let* [vector-value (cpp/cast #cpp (immer.vector int jank.memory_policy) [1 2 3])
       transient-vector-value (cpp/cast #cpp (immer.vector_transient int jank.memory_policy) [4 5])
       flex-vector-value (cpp/cast #cpp (immer.flex_vector int jank.memory_policy) '(6 7))
       empty-dvektor (#cpp (immer.dvektor int 5 jank.memory_policy))
       dvektor-value (cpp/cast #cpp (immer.dvektor int 5 jank.memory_policy) [13 14 15])
       typed-dvektor-value (cpp/cast (cpp/type (immer.dvektor int 5 jank.memory_policy)) '(16 17))
       array-value (cpp/cast #cpp (immer.array int jank.memory_policy) [8 9])
       map-value (cpp/cast #cpp (immer.map int int (std.hash int) (std.equal_to int) jank.memory_policy) [[1 10] [2 20]])
       set-value (cpp/cast #cpp (immer.set int (std.hash int) (std.equal_to int) jank.memory_policy) [1 2 2])
       box-value (#cpp (immer.box int jank.memory_policy) #cpp 42)
       typed-vector-value (cpp/cast (cpp/type (immer.vector int jank.memory_policy)) [11 12])
       _ (assert (= 3 (.size vector-value)))
       _ (assert (= 2 (.size transient-vector-value)))
       _ (assert (= 2 (.size flex-vector-value)))
       _ (assert (.empty empty-dvektor))
       _ (assert (= 3 (.size dvektor-value)))
       _ (assert (= 14 (cpp/aget dvektor-value #cpp 1)))
       _ (assert (= 2 (.size typed-dvektor-value)))
       _ (assert (= 17 (cpp/aget typed-dvektor-value #cpp 1)))
       _ (assert (= 2 (.size array-value)))
       _ (assert (= 20 (cpp/.at map-value #cpp 2)))
       _ (assert (= 1 (cpp/.count set-value #cpp 2)))
       _ (assert (= 42 (.get box-value)))
       _ (assert (= 12 (cpp/.at typed-vector-value #cpp 1)))]
  :success)
