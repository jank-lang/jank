(cpp/raw "namespace jank::cpp::cppinterop::pass_immer_prelude_table
          {
            struct row
            {
              int id{};
              int score{};

              static ::jank::runtime::obj::persistent_vector_ref into_object(row const &r)
              {
                ::jank::runtime::detail::native_transient_vector trans;
                trans.push_back(::jank::runtime::convert<int>::into_object(r.id));
                trans.push_back(::jank::runtime::convert<int>::into_object(r.score));
                return ::jank::runtime::make_box<::jank::runtime::obj::persistent_vector>(
                  trans.persistent());
              }

              static row from_object(::jank::runtime::object_ref const o)
              {
                return from_object(
                  ::jank::runtime::try_object<::jank::runtime::obj::persistent_vector>(o));
              }

              static row from_object(::jank::runtime::obj::persistent_vector_ref const o)
              {
                return { ::jank::runtime::convert<int>::from_object(o->data[0]),
                         ::jank::runtime::convert<int>::from_object(o->data[1]) };
              }
            };

            struct row_key_fn
            {
              int operator()(row const &r) const
              {
                return r.id;
              }

              row operator()(row r, int const key) const
              {
                r.id = key;
                return r;
              }
            };
          }")

(let* [table-value (cpp/cast #cpp (immer.table
                                    jank.cpp.cppinterop.pass_immer_prelude_table.row
                                    jank.cpp.cppinterop.pass_immer_prelude_table.row_key_fn
                                    (std.hash int)
                                    (std.equal_to int)
                                    jank.memory_policy)
                     [[4 [0 40]]])
       table-transient-value (cpp/cast #cpp (immer.table_transient
                                             jank.cpp.cppinterop.pass_immer_prelude_table.row
                                             jank.cpp.cppinterop.pass_immer_prelude_table.row_key_fn
                                             (std.hash int)
                                             (std.equal_to int)
                                             jank.memory_policy
                                             immer.default_bits)
                              [[5 [0 50]]])
       typed-table-value (cpp/cast (cpp/type (immer.table
                                               jank.cpp.cppinterop.pass_immer_prelude_table.row
                                               jank.cpp.cppinterop.pass_immer_prelude_table.row_key_fn
                                               (std.hash int)
                                               (std.equal_to int)
                                               jank.memory_policy))
                         [[6 [0 60]]])
       _ (assert (= 1 (.size table-value)))
       _ (assert (= 40 (cpp/.-score (cpp/.at table-value #cpp 4))))
       _ (assert (= 50 (cpp/.-score (cpp/.at table-transient-value #cpp 5))))
       _ (assert (= 60 (cpp/.-score (cpp/.at typed-table-value #cpp 6))))]
  :success)
