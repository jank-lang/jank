(cpp/raw "namespace jank::cpp::member::pass_reference_to_pointer
          {
            struct foo
            {
              i64 a{};
            };
            struct bar
            {
              foo *f;
            };
          }")
(let* [f (cpp/jank.cpp.member.pass_reference_to_pointer.foo 77)
       b (cpp/jank.cpp.member.pass_reference_to_pointer.bar (cpp/& f))
       a (.-a (.-f b))]
  (if (= 77 a)
    :success))
