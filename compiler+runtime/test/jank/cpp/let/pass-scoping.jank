(cpp/raw "namespace jank::cpp::let::pass_scoping
          {
            std::vector<std::string> actions;
            void log_action(std::string const &s)
            { actions.emplace_back(s); }

            struct foo
            {
              std::string s;
              ~foo()
              { log_action(\"foo dtor \" + s); }
            };
          }")

(cpp/jank.cpp.let.pass_scoping.log_action "1")
((fn* []
   (let* [f1 (cpp/jank.cpp.let.pass_scoping.foo #cpp "1")]
     (cpp/jank.cpp.let.pass_scoping.log_action "2")
     (let* [f2 (cpp/jank.cpp.let.pass_scoping.foo #cpp "2")])
     (cpp/jank.cpp.let.pass_scoping.log_action "3"))

   (if (= ["1" "2" "foo dtor 2" "3" "foo dtor 1"] cpp/jank.cpp.let.pass_scoping.actions)
     :success)))
