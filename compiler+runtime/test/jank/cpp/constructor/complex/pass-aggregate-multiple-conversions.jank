(cpp/raw "namespace jank::cpp::constructor::complex::pass_aggregate_multiple_conversions
          {
            struct foo
            {
              std::string name;
              u8 meow{};
            };
          }")
(let* [f (cpp/jank.cpp.constructor.complex.pass_aggregate_multiple_conversions.foo. "name" 77)]
  (if (and (= "name" (.-name f))
           (= 77 (.-meow f)))
    :success))
