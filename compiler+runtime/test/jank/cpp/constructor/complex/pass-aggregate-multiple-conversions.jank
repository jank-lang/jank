(cpp/raw "namespace jank::cpp::constructor::complex::pass_aggregate_multiple_conversions
          {
            struct foo
            {
              std::string name;
              char const *meow{};
            };
          }")
(let* [f (cpp/jank.cpp.constructor.complex.pass_aggregate_multiple_conversions.foo. #cpp "name" #cpp "meow")]
  (if (and (= "name" (cpp/.-name f))
           (= "meow" (cpp/.-meow f)))
    :success))
