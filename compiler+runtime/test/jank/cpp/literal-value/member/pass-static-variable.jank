(cpp/raw "namespace jank::cpp::literal_value::member::pass_static_variable
          {
            struct foo
            {
              static constexpr int bar = 100;
            };
          }")
(let* [i (cpp/value (:member jank.cpp.literal_value.member.pass_static_variable.foo bar))]
  (if (= i 100)
    :success))
