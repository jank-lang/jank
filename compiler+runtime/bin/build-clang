#!/usr/bin/env bash
# build-clang -- Checks out and builds a pinned Clang/LLVM for jank.
#
# See -h for all options.
#
# Configuration (edit below):
#   llvm_url / llvm_branch / llvm_commit
#       Source repository to check out from, pinned to a specific commit.
#   llvm_version
#       Major version number, used for lib install paths.
#   llvm_mingw_pkg_url / llvm_mingw_pkg_branch / llvm_mingw_pkg_commit
#       MSYS2 package definition used to build and package LLVM.
#       Contains placeholder values that this script needs to replace
#       before building. See PKGBUILD for details (Windows only).
#
# Output (in build/llvm-install/):
#   Linux/Mac  - installed LLVM tree (headers, libs, binaries)
#   Windows    - pacman .tar.zst packages (use -i to install into MSYS2)

set -euo pipefail

llvm_url="https://github.com/jank-lang/llvm-project.git"
llvm_version=23
llvm_branch="jank-snapshot/llvm${llvm_version}"
llvm_branch="jank"
llvm_commit="106644f6c835f9d2137aeb9cbfe1b9a60d03d17f"

# Windows only (MSYS2):
llvm_mingw_pkg_url="https://github.com/ikappaki/MINGW-packages"
llvm_mingw_pkg_branch="maint/llvm-up-resilience"
llvm_mingw_pkg_commit="6b27133534fb696e39996154fea565f3bb0bd331"

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
build_dir="${here}/../build"
mkdir -p "${build_dir}"
cd "${build_dir}"

# We build Clang with Clang for consistency.
export CC=clang
export CXX=clang++

set +e
  make_j="$(nproc 2>/dev/null || sysctl -n hw.logicalcpu 2>/dev/null || echo 4)"
set -e

install=0
update=0

while getopts ":hiuj:" opt; do
  case "${opt}" in
    h)
      echo "Usage ${0} [-j N] [-i] [-u] [srcdir]"
      exit 0
      ;;
    i)
      install=1
      ;;
    j)
      make_j="${OPTARG}"
      ;;
    u)
      update=1
      ;;
    \?)
      echo "Invalid option: ${OPTARG}" 1>&2
      exit 1
      ;;
    :)
      echo "Invalid option: ${OPTARG} requires an argument" 1>&2
      exit 1
      ;;
    *)
      echo "Unexpected input: ${OPTARG}" 1>&2
      exit 1
      ;;
  esac
done
shift $((OPTIND -1))

echo "Using ${make_j} cores to build"

srcdir="${PWD}"

llvm_dest_dir="${srcdir}/llvm-install"
llvm_build_dir="${srcdir}/llvm-build"

if [[ -n "${MSYSTEM:-}" ]]; then
    # Keeping Windows on 22 for now, since the mingw package relies on Github releases and 23
    # is still unreleased.
    llvm_version=22
    llvm_commit="8164f1a0c17b192e133817436bdb07598b7402a3"

    llvm_mingw_pkg_repo_dir="${build_dir}/MINGW-packages"
    # makepkg expects the source tree at ${llvm_build_dir}/src
    llvm_mingw_pkg_build_dir="${llvm_build_dir}"
    llvm_src_dir="${llvm_mingw_pkg_build_dir}/src"
else
    llvm_src_dir="${srcdir}/llvm"
fi

if [[ ${install} == 1 ]]; then
   if [[ -n "${MSYSTEM:-}" ]]; then
       pacman --noconfirm -U ${llvm_dest_dir}/*.tar.zst
       exit 0
   else
       echo "Binary package installation is only supported in the MSYS2 CLANG environment on Windows."
       exit 1
   fi
fi

function prepare()
{
  if [[ ! -d "${llvm_src_dir}" ]];
  then
    git clone --no-checkout --filter=blob:none --depth 1 "${llvm_url}" "${llvm_src_dir}"
    cd "${llvm_src_dir}"
      git fetch origin "${llvm_commit}" --depth 1
      git checkout "${llvm_commit}"
      git submodule update --init --depth 1 --recursive
    cd -
  elif [[ ${update} == 1 ]];
  then
    cd ${llvm_src_dir}
      git stash || true
      git checkout "${llvm_branch}"
      git pull origin "${llvm_branch}"
    cd -
  fi

  mkdir -p ${llvm_build_dir}

  if [[ -n "${MSYSTEM:-}" ]]; then
      pacman --noconfirm -S base-devel git

      echo "Cloning MINGW-packages repo to ${llvm_mingw_pkg_repo_dir}..."
      rm -fr ${llvm_mingw_pkg_repo_dir}
      # Clone the repo shallowly and check out only the mingw-w64-llvm directory
      git clone --depth 1 --branch ${llvm_mingw_pkg_branch} --filter=blob:none --no-checkout ${llvm_mingw_pkg_url} ${llvm_mingw_pkg_repo_dir}
      cd ${llvm_mingw_pkg_repo_dir}
        git sparse-checkout init --cone
        git sparse-checkout set mingw-w64-llvm
        git checkout ${llvm_mingw_pkg_commit}
      cd -
      cp ${llvm_mingw_pkg_repo_dir}/mingw-w64-llvm/* ${llvm_mingw_pkg_build_dir}

      # e.g.   set(LLVM_VERSION_MAJOR 22)
      LLVM_VERSION_MAJOR=$(sed -n 's/^[[:space:]]*set(LLVM_VERSION_MAJOR \([0-9]*\))/\1/p' ${llvm_src_dir}/cmake/Modules/LLVMVersion.cmake)
      LLVM_VERSION_MINOR=$(sed -n 's/^[[:space:]]*set(LLVM_VERSION_MINOR \([0-9]*\))/\1/p' ${llvm_src_dir}/cmake/Modules/LLVMVersion.cmake)
      LLVM_VERSION_PATCH=$(sed -n 's/^[[:space:]]*set(LLVM_VERSION_PATCH \([0-9]*\))/\1/p' ${llvm_src_dir}/cmake/Modules/LLVMVersion.cmake)
      LLVM_VERSION_SUFFIX=$(sed -n 's/^[[:space:]]*set(LLVM_VERSION_SUFFIX \(.*\))/\1/p'   ${llvm_src_dir}/cmake/Modules/LLVMVersion.cmake)
      LLVM_COMMIT_HASH=$(git -C ${llvm_src_dir} rev-parse --short HEAD)

      sed -i "s/PLACEHOLDER-PKGVER/${LLVM_VERSION_MAJOR}.${LLVM_VERSION_MINOR}.${LLVM_VERSION_PATCH}${LLVM_VERSION_SUFFIX}/" ${llvm_mingw_pkg_build_dir}/PKGBUILD
      sed -i "s/PLACEHOLDER-PKGREL/jank_${LLVM_COMMIT_HASH}/" ${llvm_mingw_pkg_build_dir}/PKGBUILD
  fi
}

function build()
{
  mkdir -p "${llvm_build_dir}"
  cd "${llvm_build_dir}"

  cmake -DCMAKE_BUILD_TYPE=Release \
        -DLLVM_ENABLE_RUNTIMES="libcxx;libcxxabi;libunwind;compiler-rt" \
        -DLLVM_BUILD_LLVM_DYLIB=ON \
        -DLLVM_LINK_LLVM_DYLIB=ON \
        -DLLVM_ENABLE_PROJECTS="clang;clang-tools-extra" \
        -DLLVM_TARGETS_TO_BUILD="host" \
        -DLLVM_ENABLE_EH=ON \
        -DLLVM_ENABLE_RTTI=ON \
        -DLLVM_INCLUDE_BENCHMARKS=OFF \
        -DLLVM_ENABLE_BINDINGS=OFF \
        -DLLVM_INCLUDE_EXAMPLES=OFF \
        -DLLVM_INCLUDE_TESTS=OFF \
        -DLLVM_ENABLE_ZSTD=OFF \
        -DLLVM_BUILD_OCAML_BINDINGS=OFF \
        -DLLVM_ENABLE_OCAMLDOC=OFF \
        -G "Ninja" \
        ${llvm_src_dir}/llvm

  export DESTDIR="${llvm_dest_dir}"
  ninja clang clang-repl compiler-rt clang-cpp clang-tidy install -j"${make_j}"
  mkdir -p "${DESTDIR}/usr/local/lib/clang/${llvm_version}/lib"
  cp -r lib/clang/"${llvm_version}"/lib/* "${DESTDIR}/usr/local/lib/clang/${llvm_version}/lib/"
}

function build_mingw()
{
    cd ${llvm_build_dir}
    makepkg-mingw -sLf --nocheck
    rm -fr ${llvm_dest_dir}
    mkdir -p ${llvm_dest_dir}
    mv ${llvm_build_dir}/*.tar.zst ${llvm_dest_dir}
    echo "LLVM binary packages copied to ${llvm_dest_dir}."
}

prepare
if [[ -n "${MSYSTEM:-}" ]]; then build_mingw; else build; fi

echo
echo "Clang/LLVM successfully compiled. You can now build jank."
