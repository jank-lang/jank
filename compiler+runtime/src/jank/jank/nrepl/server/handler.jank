(ns jank.nrepl.server.handler)

(def xx (atom 0))
(defmulti handle-message #(do
                            (swap! xx inc)
                            (spit (str "/tmp/jank-nrepl-handle-" @xx) (str %))
                            (some-> (get % "op") keyword)))



(defmethod handle-message :default [msg]
  ;; Behavior from: https://github.com/nrepl/nrepl/blob/3cc751a/src/clojure/nrepl/server.clj#L111

  (spit (str "/tmp/jank-nrepl-error-" @xx) (str msg))
  {:status [:error :unknown-op :done]})
